@echo off
cd /d "%~dp0"
powershell -NoProfile -Command "$wd = @(Get-CimInstance Win32_Process | Where-Object { $_.Name -eq 'pythonw.exe' -and $_.CommandLine -match 'watchdog\.py' }); $orphan = @(Get-CimInstance Win32_Process | Where-Object { $_.Name -eq 'python.exe' -and $_.CommandLine -match 'app\.py' }); if ($wd.Count -gt 0) { Write-Host ('[start] watchdog already running PID=' + $wd[0].ProcessId + ' -- skip') -ForegroundColor Yellow; exit }; if ($orphan.Count -gt 0) { foreach ($p in $orphan) { Stop-Process -Id $p.ProcessId -Force -ErrorAction SilentlyContinue; Write-Host ('[start] killed orphan app PID=' + $p.ProcessId) -ForegroundColor DarkYellow }; Start-Sleep 1 }; Start-Process pythonw.exe watchdog.py -WindowStyle Hidden; Start-Sleep 3; $r = @(Get-CimInstance Win32_Process | Where-Object { $_.Name -eq 'pythonw.exe' -and $_.CommandLine -match 'watchdog\.py' }); if ($r.Count -gt 0) { $a = @(Get-CimInstance Win32_Process | Where-Object { $_.Name -eq 'python.exe' -and $_.CommandLine -match 'app\.py' }); Write-Host ('[start] watchdog PID=' + $r[0].ProcessId) -ForegroundColor Green; if ($a.Count -gt 0) { Write-Host ('[start] app PID=' + $a[0].ProcessId) -ForegroundColor Green }; Write-Host '[start] open http://localhost:5678' } else { Write-Host '[start] FAILED' -ForegroundColor Red }"
pause
